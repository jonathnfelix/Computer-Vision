"""
TrafficLightController: state machine adaptive traffic light.

Cycle:
  Lane_0 GREEN -> Lane_0 YELLOW -> ALL_RED -> Lane_1 GREEN -> ...

Adaptive logic:
  Saat masuk fase GREEN untuk suatu lane, hitung durasi green
  berdasarkan proporsi vehicle_count lane tsb relatif terhadap
  total seluruh lane. Dibatasi [MIN_GREEN, MAX_GREEN].

Smoothing:
  Counts per lane di-rolling-average untuk hindari fluktuasi
  frame-by-frame.
"""

import time
from collections import deque


class TrafficLightController:
    def __init__(
        self,
        lane_names: list,
        base_green: float = 15.0,
        min_green: float = 8.0,
        max_green: float = 45.0,
        yellow_time: float = 3.0,
        all_red_time: float = 2.0,
        smoothing_window: int = 10,
    ):
        if len(lane_names) < 2:
            raise ValueError("Butuh minimal 2 lane untuk traffic light.")

        self.lane_names = lane_names
        self.base_green = float(base_green)
        self.min_green = float(min_green)
        self.max_green = float(max_green)
        self.yellow_time = float(yellow_time)
        self.all_red_time = float(all_red_time)

        # Rolling buffer count per lane untuk smoothing
        self._count_buffers = {
            name: deque(maxlen=smoothing_window) for name in lane_names
        }

        # State machine
        self.current_lane_idx = 0
        self.phase = "GREEN"  # GREEN | YELLOW | ALL_RED
        self.phase_duration = base_green
        self.phase_start_time = time.time()

        # Stats untuk display & evaluasi nanti
        self.cycle_count = 0
        self.history = []  # list of {lane, green_duration, count_at_start}

    # ------------------------------------------------------------
    # COUNT UPDATE
    # ------------------------------------------------------------
    def update_counts(self, counts: dict) -> None:
        """Push count terbaru ke rolling buffer per lane."""
        for lane in self.lane_names:
            self._count_buffers[lane].append(counts.get(lane, 0))

    def get_smoothed_counts(self) -> dict:
        """Rata-rata count per lane dari buffer."""
        result = {}
        for lane in self.lane_names:
            buf = self._count_buffers[lane]
            result[lane] = (sum(buf) / len(buf)) if buf else 0.0
        return result

    # ------------------------------------------------------------
    # ADAPTIVE GREEN TIME COMPUTATION
    # ------------------------------------------------------------
    def _compute_green_time(self, lane_name: str) -> float:
        """
        Durasi green proporsional terhadap count lane ini vs total counts.
        Dibatasi [min_green, max_green].
        """
        smoothed = self.get_smoothed_counts()
        total = sum(smoothed.values())

        if total <= 0:
            # Semua lane kosong -> pakai baseline
            return self.base_green

        proportion = smoothed[lane_name] / total
        n_lanes = len(self.lane_names)

        # Alokasikan: base * n_lanes * proportion
        # (kalau proporsi merata 1/n_lanes -> hasil = base_green)
        green = self.base_green * n_lanes * proportion

        # Clamp [min, max]
        green = max(self.min_green, min(self.max_green, green))
        return float(green)

    # ------------------------------------------------------------
    # STATE MACHINE STEP
    # ------------------------------------------------------------
    def step(self) -> dict:
        """Advance state machine kalau durasi fase saat ini habis."""
        elapsed = time.time() - self.phase_start_time

        if elapsed >= self.phase_duration:
            if self.phase == "GREEN":
                self.phase = "YELLOW"
                self.phase_duration = self.yellow_time

            elif self.phase == "YELLOW":
                self.phase = "ALL_RED"
                self.phase_duration = self.all_red_time

            elif self.phase == "ALL_RED":
                # Pindah ke lane berikutnya
                self.current_lane_idx = (self.current_lane_idx + 1) % len(self.lane_names)
                next_lane = self.lane_names[self.current_lane_idx]
                self.phase = "GREEN"
                self.phase_duration = self._compute_green_time(next_lane)

                # Log siklus
                smoothed = self.get_smoothed_counts()
                self.history.append({
                    "cycle": self.cycle_count,
                    "lane": next_lane,
                    "green_duration": self.phase_duration,
                    "count_at_start": smoothed[next_lane],
                    "all_counts": dict(smoothed),
                })
                self.cycle_count += 1

            self.phase_start_time = time.time()

        return self.get_state()

    def get_state(self) -> dict:
        """Snapshot state saat ini untuk visualisasi."""
        elapsed = time.time() - self.phase_start_time
        time_remaining = max(0.0, self.phase_duration - elapsed)
        current_lane = self.lane_names[self.current_lane_idx]

        # State per lane: lane aktif sesuai self.phase, sisanya RED
        states = {}
        for lane in self.lane_names:
            states[lane] = self.phase if lane == current_lane else "RED"

        return {
            "states": states,
            "current_lane": current_lane,
            "phase": self.phase,
            "time_remaining": time_remaining,
            "phase_duration": self.phase_duration,
            "smoothed_counts": self.get_smoothed_counts(),
            "cycle_count": self.cycle_count,
        }
